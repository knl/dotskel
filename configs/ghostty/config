# theme = light:"Tango Half Adapted",dark:tempus_night
theme = light:"Tempus Day",dark:"Tempus Night"

cursor-style = block
cursor-style-blink = true
cursor-invert-fg-bg = true
shell-integration-features = no-cursor

copy-on-select = clipboard

window-inherit-working-directory = false
tab-inherit-working-directory = false
split-inherit-working-directory = true

window-step-resize = true

macos-option-as-alt = true

font-family = "Iosevka Term SS08"
# font-family = "IosevkaTerm Nerd Font"

font-size = 18.0

notify-on-command-finish = unfocused
notify-on-command-finish-action = no-bell,notify
notify-on-command-finish-after = 30s

# clear screen on Cmd+K (from iTerm2)
keybind = cmd+k=clear_screen
keybind = shift+enter=text:\x1b\r

# use ctrl+, to change the tab title
keybind = ctrl+,=prompt_tab_title
